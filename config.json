{
  "settings": 
    {"virt_env": "/media/stuff/Development/virt_env/rocm/bin/python", "hsa": { "ver": "11.0.0", "enabled": false}},
    "model": {"exaggeration": 0.5, "cfg_weight": 0.5, "temp": 0.8, "path": "/media/stuff/Development/models/chatterbox"},
  "presets": 
    {"fallback": {"source": "Example", "destination": "Audio", "language": "English", "voice": "en_default.mp3"}},
  "regex_rules": [{"Pattern": "&nbsp;", "Replace": " ", "Comment": "Replace non-breaking spaces with ' '"},
    {"Pattern": "<\\/?span.*?>|<br\\s*/?>", "Replace": " ", "Comment": "Replace <span> and <br> tags with ' '"},
    {"Pattern": "\\[.*\\]", "Replace": "", "Comment": "Ignore text in []."},
    {"Pattern": "(\\(|\\))", "Replace": "", "Comment": "Remove (). Chatterbox puts emphasis on text inside ()"},
    {"Pattern": "{{[^{}:]*::([^{}:]*)(::[^{}:]*)?}}", "Replace": "\\1", "Comment": "Remove cloze brackets {{c1::...}}"},
    {"Pattern": "<div.*?>(.*?)<\\/div>", "Replace": "\\1", "Comment": "Remove complete <div> blocks"},
    {"Pattern": "<\\/?div>", "Replace": "", "Comment": "Remove single <div> blocks"}
  ]
}

